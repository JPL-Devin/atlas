# !!!This file gets checked into github to support the static build!!!
REACT_APP_VERSION = "v1.0.0"
REACT_APP_CLEARANCE_NUMBER = "CL#23-3080"
REACT_APP_LAST_UPDATED = "January 21, 2026"

PUBLIC_URL = "/beta"

# Local development now points at the Atlas API layer in `api/`.
# The previous direct Elasticsearch proxy values are kept as comments for reference.
#REACT_APP_DOMAIN = "https://pds-imaging.jpl.nasa.gov/api"
#REACT_APP_DOMAIN = "https://nckyqwyyoc.execute-api.us-west-2.amazonaws.com/v1"
REACT_APP_DOMAIN = "http://localhost:3001/api"
REACT_APP_DATA_ENDPOINT = "/data"
REACT_APP_SEARCH_ENDPOINT = "/search"
REACT_APP_PIT_ENDPOINT = "/search/scroll"
REACT_APP_SCROLL_ENDPOINT = "/search/scroll"
REACT_APP_ARCHIVE_ENDPOINT = "/search"

GENERATE_SOURCEMAP = "false"

