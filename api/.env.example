# Elasticsearch connection URL (e.g. https://es.example.com:9200 or the AWS API Gateway proxy URL).
ELASTICSEARCH_URL=https://nckyqwyyoc.execute-api.us-west-2.amazonaws.com/v1/search

# Primary index containing planetary metadata.
ELASTICSEARCH_INDEX=atlas

# Optional credentials for basic-auth Elasticsearch deployments. Leave blank for unauthenticated proxies.
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_API_KEY=

# Whether to verify TLS certificates against the connection.
ELASTICSEARCH_TLS_REJECT_UNAUTHORIZED=true

# Port that the API server listens on.
PORT=3001

# Comma-separated list of CORS origins allowed to call this API.
CORS_ORIGIN=http://localhost:3000

# Optional: maximum number of product IDs accepted per /api/cart/download request.
MAX_BULK_DOWNLOAD_COUNT=25000
